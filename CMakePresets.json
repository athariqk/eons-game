{
    "version": 3,
    "configurePresets": [
		{
			"name": "windows-debug",
			"displayName": "Windows Debug x64 (Ninja + vcpkg)",
			"description": "Uses Ninja generator and vcpkg for dependencies",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"VCPKG_TARGET_TRIPLET": "x64-windows",
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
			}
		},
		{
			"name": "windows-release",
			"displayName": "Windows Release x64 (Ninja + vcpkg)",
			"description": "Uses Ninja generator and vcpkg for dependencies",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"VCPKG_TARGET_TRIPLET": "x64-windows",
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
			}
		}
    ]
}
