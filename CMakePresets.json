{
	"version": 3,
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
			}
		},
		{
			"name": "windows-base",
			"hidden": true,
			"inherits": "base",
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "x64-windows"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		},
		{
			"name": "linux-base",
			"hidden": true,
			"inherits": "base",
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "x64-linux"
			},
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Linux"
			}
		},
		{
			"name": "windows-debug",
			"displayName": "Windows Debug x64",
			"inherits": "windows-base",
			"binaryDir": "${sourceDir}/build/windows-debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "windows-release",
			"displayName": "Windows Release x64",
			"inherits": "windows-base",
			"binaryDir": "${sourceDir}/build/windows-release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "windows-dist",
			"displayName": "Windows Dist x64",
			"inherits": "windows-base",
			"binaryDir": "${sourceDir}/build/windows-dist",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Dist"
			}
		},
		{
			"name": "linux-debug",
			"displayName": "Linux Debug x64",
			"inherits": "linux-base",
			"binaryDir": "${sourceDir}/build/linux-debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "linux-release",
			"displayName": "Linux Release x64",
			"inherits": "linux-base",
			"binaryDir": "${sourceDir}/build/linux-release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		}
	],
	"buildPresets": [
		{
			"name": "windows-debug",
			"configurePreset": "windows-debug",
			"displayName": "Build Windows Debug"
		},
		{
			"name": "windows-release",
			"configurePreset": "windows-release",
			"displayName": "Build Windows Release"
		},
		{
			"name": "windows-dist",
			"configurePreset": "windows-dist",
			"displayName": "Build Windows Dist"
		},
		{
			"name": "linux-debug",
			"configurePreset": "linux-debug",
			"displayName": "Build Linux Debug"
		},
		{
			"name": "linux-release",
			"configurePreset": "linux-release",
			"displayName": "Build Linux Release"
		}
	]
}
